{
  "info": {
    "_postman_id": "1c36faaa-03d4-4b38-9af3-8d8d8e5adf0c",
    "name": "Farm Game Store Back - Full API",
    "description": "Coleccion para probar todos los servicios de la API: health, login y CRUD completo de productos con JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const mode = ((pm.variables.get('baseUrlMode') || pm.collectionVariables.get('baseUrlMode')) || 'local').toLowerCase();",
          "const localUrl = pm.variables.get('baseUrlLocal') || pm.collectionVariables.get('baseUrlLocal');",
          "const prodUrl = pm.variables.get('baseUrlProd') || pm.collectionVariables.get('baseUrlProd');",
          "const selectedUrl = mode === 'prod' ? prodUrl : localUrl;",
          "pm.collectionVariables.set('baseUrl', selectedUrl);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var data = pm.response.json();",
                  "pm.test('Health ok=true', function () {",
                  "  pm.expect(data).to.have.property('ok', true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "POST /auth/login (OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var data = pm.response.json();",
                  "pm.test('Retorna token', function () {",
                  "  pm.expect(data).to.have.property('type', 'Bearer');",
                  "  pm.expect(data).to.have.property('token');",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /auth/login (401 credenciales invalidas)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"password_invalido\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
