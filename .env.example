PORT=3000
# Requeridas siempre para auth (en produccion son obligatorias, sin fallback)
JWT_SECRET=replace_with_secure_jwt_secret
AUTH_USER_EMAIL=replace_with_login_email@example.com
AUTH_USER_PASSWORD=replace_with_login_password

# Opcionales para login de Firebase Auth (si no se definen, se reutilizan AUTH_USER_*)
FIREBASE_AUTH_EMAIL=replace_with_firebase_auth_email@example.com
FIREBASE_AUTH_PASSWORD=replace_with_firebase_auth_password

# Requeridas para conectar Firestore
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Recomendado para pruebas/entrega
FIREBASE_PRODUCTS_COLLECTION=products-test

# Opcionales de logging
# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LOG_COLOR=1
